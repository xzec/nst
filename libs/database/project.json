{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "db",
  "sourceRoot": "libs/database/src",
  "projectType": "application",
  "namedInputs": {
    "schema": ["{projectRoot}/src/schema.ts"]
  },
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit generate",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["schema"],
      "outputs": ["{projectRoot}/src/drizzle"]
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit migrate",
        "cwd": "libs/database"
      }
    },
    "seed:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsdown src/seed.ts",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/dist/seed.mjs"]
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/seed.mjs",
        "cwd": "libs/database"
      },
      "dependsOn": ["seed:build"]
    },
    "studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit studio",
        "cwd": "libs/database"
      }
    }
  }
}
