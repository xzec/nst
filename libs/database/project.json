{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "db",
  "sourceRoot": "libs/database/src",
  "projectType": "application",
  "namedInputs": {
    "schema": ["{projectRoot}/src/schema"]
  },
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsdown",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src", "schema", "sharedGlobals"],
      "outputs": ["{projectRoot}/dist"]
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit generate",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["schema", "sharedGlobals"],
      "outputs": ["{projectRoot}/src/drizzle"]
    },
    "migrate": {
      "dependsOn": ["post-migrate"]
    },
    "post-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/post-migrate.ts",
        "cwd": "libs/database"
      },
      "dependsOn": ["drizzle-kit-migrate"]
    },
    "drizzle-kit-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit migrate",
        "cwd": "libs/database"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/seed.ts",
        "cwd": "libs/database"
      }
    },
    "studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit studio",
        "cwd": "libs/database"
      }
    }
  }
}
