{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "db",
  "sourceRoot": "libs/database/src",
  "projectType": "application",
  "namedInputs": {
    "schema": ["{projectRoot}/src/schema.ts"]
  },
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsdown --filter database",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/schema/**/*", "sharedGlobals"],
      "outputs": ["{projectRoot}/dist/database"]
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit generate",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["schema"],
      "outputs": ["{projectRoot}/src/drizzle"]
    },
    "migrate": {
      "dependsOn": ["post-migrate"]
    },
    "post-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/post-migrate/post-migrate.mjs",
        "cwd": "libs/database"
      },
      "dependsOn": ["post-migrate:build"]
    },
    "post-migrate:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsdown --filter post-migrate",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/scripts/post-migrate.ts", "sharedGlobals"],
      "outputs": ["{projectRoot}/dist/post-migrate/post-migrate.mjs"],
      "dependsOn": ["drizzle-kit-migrate"]
    },
    "drizzle-kit-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit migrate",
        "cwd": "libs/database"
      }
    },
    "seed:build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsdown --filter seed",
        "cwd": "libs/database"
      },
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/dist/seed/seed.mjs"]
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/seed/seed.mjs",
        "cwd": "libs/database"
      },
      "dependsOn": ["seed:build"]
    },
    "studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit studio",
        "cwd": "libs/database"
      }
    }
  }
}
